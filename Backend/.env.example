# ─────────────────────────────────────────────────────────────
# CI/CD Platform API – Environment Configuration
# ─────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB – Local first, then swap to Atlas
# Local:  mongodb://localhost:27017/cidc
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/cidc?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/cidc

# JWT Authentication
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_EXPIRE=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
